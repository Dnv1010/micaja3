# Google Sheets / Drive — Service Account
GOOGLE_SERVICE_ACCOUNT_EMAIL=micaja@proyecto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# IDs de spreadsheets
PETTY_CASH_SPREADSHEET_ID=
QUICKFUNDS_SPREADSHEET_ID=
# Libro MiCaja (ParametrosPdf, Ciudad, Balance, pestaña Usuarios, etc.)
# El ID es el texto entre /d/ y /edit en la URL, ej:
# https://docs.google.com/spreadsheets/d/1sVDPDsDRL9MiiTrzp6YID7k9h9ZaayE50WAEyodZF1k/edit
MICAJA_SPREADSHEET_ID=
# Opcional: tercer libro con Usuarios (se suma a Petty + MiCaja; no sustituye)
USUARIOS_SPREADSHEET_ID=
# Si la pestaña no se llama exactamente "Usuarios", define el nombre aquí
USUARIOS_SHEET_NAME=Usuarios
# En la hoja Usuarios: columna opcional PIN (texto, 4 dígitos). Si está vacía, solo Google OAuth.

# Carpetas Google Drive
# Raíz compartida con la service account (p. ej. carpeta "Facturas" dentro de MiCaja)
GOOGLE_DRIVE_FOLDER_ID=
# Compatibilidad: si GOOGLE_DRIVE_FOLDER_ID está vacío, se usa este valor
GOOGLE_DRIVE_FACTURAS_FOLDER_ID=
GOOGLE_DRIVE_INFORMES_FOLDER_ID=

# NextAuth
# En Vercel: NEXTAUTH_URL debe ser la URL pública exacta, ej. https://micaja.vercel.app (sin barra final)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# En Google Cloud → Credenciales → OAuth: URI de redirección autorizada:
#   https://TU-DOMINIO.vercel.app/api/auth/callback/google

# Google AI Studio — resumen ejecutivo de reportes de legalización (Gemini)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Resend — envío "Enviar a FX" (reportes firmados). RESEND_FX_TO: destinatarios separados por coma
RESEND_API_KEY=
RESEND_FROM=MiCaja BIA Energy <onboarding@resend.dev>
RESEND_FX_TO=dinovi.sanchez@bia.app

# OCR.Space (plan gratuito)
OCR_SPACE_API_KEY=

# App
NEXT_PUBLIC_APP_NAME=MiCaja
NEXT_PUBLIC_MONTO_ASIGNADO=3000000
# URL pública (enlaces en notificaciones). En Vercel suele inferirse vía VERCEL_URL
NEXT_PUBLIC_APP_URL=

# Telegram — Bot (@BotFather) y webhook
TELEGRAM_BOT_TOKEN=
# Opcional: mismo valor que pasas a setWebhook; Telegram lo envía en X-Telegram-Bot-Api-Secret-Token
TELEGRAM_WEBHOOK_SECRET=
# Solo desarrollo: GET /api/dev/test-telegram
TELEGRAM_TEST_CHAT_ID=

# APIs internas (webhook Telegram → upload + factura). Genera un string largo aleatorio
INTERNAL_API_KEY=

# Opcional (Node 22+): el aviso DEP0169 viene de openid-client (NextAuth v4), no de tu código.
# En Vercel también está en vercel.json; si lo quitas, puedes añadir en el dashboard:
# NODE_OPTIONS=--disable-warning=DEP0169
